{
  "name": "@openclaw-wechat/claude-code-channel",
  "version": "0.1.0",
  "description": "WeChat to Claude Code bridge using ClawBot ilink API and MCP Channel protocol",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "wechat-channel": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "bun run dist/cli.js",
    "login": "bun run dist/cli.js login",
    "logout": "bun run dist/cli.js logout",
    "status": "bun run dist/cli.js status",
    "allow": "bun run dist/cli.js allow"
  },
  "keywords": [
    "wechat",
    "claude-code",
    "mcp",
    "channel",
    "clawbot",
    "ilink"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  }
}
